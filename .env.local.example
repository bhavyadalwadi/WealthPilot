OPENAI_API_KEY=

# Prisma reads DATABASE_URL from `.env` for local SQLite. This file stays useful
# for app-only overrides if you want them.

# Required for the site-wide private gate in both local dev and Vercel.
PRIVATE_ACCESS_USERNAME=
PRIVATE_ACCESS_PASSWORD=
SESSION_SECRET=

# For OpenAI-compatible vendors or self-hosted gateways.
LLM_API_KEY=
LLM_BASE_URL=

# Optional: auto-selects the live Alpha Vantage data adapters when present.
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=

# Optional: set to "mock" to force the deterministic mock data adapters.
DATA_PROVIDER=auto

# Optional locally. Local auto resolves to sqlite; Vercel auto resolves to postgres.
STORAGE_DRIVER=auto
