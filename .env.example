DATABASE_URL="file:./dev.db"

OPENAI_API_KEY=

# Required for the site-wide private gate in local dev and Vercel.
PRIVATE_ACCESS_USERNAME=
PRIVATE_ACCESS_PASSWORD=

# For OpenAI-compatible vendors or self-hosted gateways.
LLM_API_KEY=
LLM_BASE_URL=

# Optional: auto-selects the live Alpha Vantage data adapters when present.
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=

# Optional: set to "mock" to force the deterministic mock data adapters.
DATA_PROVIDER=auto

# Local default is sqlite to match debt-crusher. Set Neon `DATABASE_URL` in Vercel prod.
STORAGE_DRIVER=auto
